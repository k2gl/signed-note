{
  "name": "k2gl/signed-note",
  "description": "Parse, verify and sign signed notes — the transparency-log / Go sumdb format used by Sigstore Rekor checkpoints — in PHP.",
  "homepage": "https://github.com/k2gl/signed-note",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "signed-note",
    "note",
    "transparency-log",
    "checkpoint",
    "sumdb",
    "sigstore",
    "rekor",
    "ed25519",
    "signing",
    "supply-chain"
  ],
  "authors": [
    {
      "name": "Nick Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/signed-note/issues",
    "source": "https://github.com/k2gl/signed-note"
  },
  "require": {
    "php": ">=8.1",
    "k2gl/dsse": "^1.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10|^11|^12",
    "phpstan/phpstan": "^2.1",
    "laravel/pint": "~1.20.0",
    "k2gl/phpunit-fluent-assertions": "^12",
    "k2gl/composer-attest": "^1.1",
    "k2gl/composer-license-gate": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "k2gl/composer-attest": true,
      "k2gl/composer-license-gate": true
    }
  },
  "extra": {
    "k2gl-attest": {
      "mode": "warn"
    },
    "k2gl-license-gate": {
      "mode": "warn",
      "allow": ["MIT", "BSD-2-Clause", "BSD-3-Clause", "Apache-2.0", "ISC"]
    }
  },
  "suggest": {
    "ext-sodium": "Required for Ed25519 notes (the standard sumdb/checkpoint algorithm).",
    "ext-openssl": "Required to verify ECDSA-signed notes, such as Rekor v1 checkpoints."
  },
  "autoload": {
    "psr-4": {
      "K2gl\\SignedNote\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "K2gl\\SignedNote\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "pint --test",
    "cs-fix": "pint",
    "check": [
      "@test",
      "@phpstan",
      "@cs"
    ]
  }
}
